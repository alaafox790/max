{
  "entities": {
    "trainee_data": {
      "title": "Trainee Detailed Data",
      "description": "Information about a trainee registration",
      "type": "object",
      "properties": {
        "registration_number": { "type": "string" },
        "track_name": { "type": "string" },
        "first_name": { "type": "string" },
        "father_name": { "type": "string" },
        "grade": { "type": "string" },
        "division": { "type": "string" },
        "school_name": { "type": "string" },
        "reason_for_choosing": { "type": "string" },
        "ai_knowledge": { "type": "string" },
        "created_at": { "type": "timestamp" }
      },
      "required": ["registration_number", "track_name", "first_name", "father_name", "grade", "division", "school_name", "reason_for_choosing", "ai_knowledge", "created_at"]
    }
  },
  "firestore": {
    "trainee_detailed_data": {
      "schema": { "$ref": "#/entities/trainee_data" },
      "description": "Collection storing all valid trainee registrations"
    }
  }
}
